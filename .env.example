# .env.example - Configuration for langgraph-agentic-scaffold (LAS)

# ===================================================================
#  System Configuration
# ===================================================================

# The workspace directory where specialists can read/write files safely.
# This defines the sandbox boundary for FileSpecialist operations.
# - Non-Docker: relative path from project root (default: "workspace")
# - Docker: set to /workspace in docker-compose.yml for container consistency
WORKSPACE_PATH=workspace

# ===================================================================
#  LLM Provider Configuration
# ===================================================================
# This file stores secrets and connection details for LLM providers.
# Copy this file to .env and fill in the required values.

# ===================================================================
# CLOUD PROVIDERS
# ===================================================================

# Required for Google Gemini. Your API key for the Google AI platform.
# Used by the 'gemini_pro' and 'gemini_flash' providers in user_settings.yaml.
# Get your API key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY="your-google-api-key"

# TIERED CHAT TIP: Gemini Flash is recommended for progenitors due to:
# - Fast parallel execution (both progenitors run simultaneously)
# - Cost-effective for 2x model calls per turn
# - Good quality for conversational responses
# Upgrade to Gemini Pro for production quality.

# ===================================================================
# LOCAL PROVIDERS (Zero API Cost)
# ===================================================================

# Local Inference Server Configuration
# Works with any OpenAI-compatible server: llama-server, LM Studio, vLLM, etc.
# Used by "local" and "local_pool" provider types in user_settings.yaml.

# Default server (fallback when no `server:` specified in user_settings.yaml)
LOCAL_INFERENCE_BASE_URL="http://localhost:1234/v1"

# DISTRIBUTED INFERENCE (Multi-GPU Box Setup):
# Define physical machines here, reference by name in user_settings.yaml with `server: "name"`
# Format: "name1=url1,name2=url2" (uses = since URLs contain :)
# Example: LOCAL_INFERENCE_SERVERS="rtx3090=http://192.168.1.100:8081/v1,rtx8000=http://192.168.1.101:1234/v1"
# LOCAL_INFERENCE_TIMEOUT=180

# PER-SERVER AUTHENTICATION (#235):
# If servers require auth tokens, define them here and reference
# in user_settings.yaml with api_key: "${LOCAL_RTX3090_KEY}"
# LOCAL_RTX3090_KEY="sk-..."
# LOCAL_RTX8000_KEY="sk-..."

# OLLAMA SUPPORT - NOT YET IMPLEMENTED
# The Ollama adapter is planned but not currently available.
# Uncomment and configure when Ollama support is added:
# OLLAMA_BASE_URL="http://localhost:11434"

# ===================================================================
# WEB SEARCH PROVIDERS
# ===================================================================

# Brave Search API - Fallback when DuckDuckGo is rate limited
# Free tier: 2,000 requests/month (no aggressive rate limiting)
# Sign up: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY="your-brave-search-api-key"

# ===================================================================
# NAVIGATOR MCP (ADR-CORE-027)
# ===================================================================
# Navigator provides tree traversal for filesystem and browser operations.
# Uses Fara-7B (Microsoft's agentic vision model) for visual grounding.

# Fara model IDs - priority list of acceptable model names in LM Studio
# FARA_MODEL_IDS="microsoft_fara-7b"

# Fara failure/retry settings
# FARA_MAX_FAILURES=2
# FARA_MIN_CONFIDENCE=0.7
# FARA_MAX_AGENT_STEPS=20

# Navigator logging level
# NAVIGATOR_LOG_LEVEL=INFO

# ===================================================================
# PROMPT-PRIX MCP (Evaluation Harness)
# ===================================================================
# prompt-prix uses its own server variables (LM_STUDIO_SERVER_N pattern).
# These are the same physical servers LAS uses, but addressed differently:
# - LAS uses LOCAL_INFERENCE_SERVERS="name=url" format for its adapter
# - prompt-prix uses LOCAL_INFERENCE_SERVER_1, LOCAL_INFERENCE_SERVER_2, etc. for its adapter
# Both adapters can coexist — they manage their own connection pools independently.
LOCAL_INFERENCE_SERVER_1=http://host.docker.internal:1234
LOCAL_INFERENCE_SERVER_2=http://192.168.137.2:1234

# ===================================================================
#  Application & Observability
# ===================================================================

# Enable and set an output path to enable Archiver reports
# AGENTIC_SCAFFOLD_ARCHIVER_ENABLED="true"
# AGENTIC_SCAFFOLD_ARCHIVE_PATH="/path/to/my/reports"

# Control integration with LangSmith to trace the scaffold's LangGraph process flow
# export LANGSMITH_TRACING="true"
# export LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# export LANGSMITH_API_KEY="<your-api-key>"
# export LANGSMITH_PROJECT="<your-langsmith-project>"

# *Currently only related to your LangSmith configuration*
# export OPENAI_API_KEY=<your-openai-api-key>