# .env.example - Configuration for langgraph-agentic-scaffold (LAS)

# ===================================================================
#  System Configuration
# ===================================================================

# The workspace directory where specialists can read/write files safely.
# This defines the sandbox boundary for FileSpecialist operations.
# Defaults to "workspace" relative to the project root.
WORKSPACE_PATH=workspace

# ===================================================================
#  LLM Provider Configuration
# ===================================================================
# This file stores secrets and connection details for LLM providers.
# Copy this file to .env and fill in the required values.

# ===================================================================
# CLOUD PROVIDERS
# ===================================================================

# Required for Google Gemini. Your API key for the Google AI platform.
# Used by the 'gemini_pro' and 'gemini_flash' providers in user_settings.yaml.
# Get your API key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY="your-google-api-key"

# TIERED CHAT TIP: Gemini Flash is recommended for progenitors due to:
# - Fast parallel execution (both progenitors run simultaneously)
# - Cost-effective for 2x model calls per turn
# - Good quality for conversational responses
# Upgrade to Gemini Pro for production quality.

# ===================================================================
# LOCAL PROVIDERS (Zero API Cost)
# ===================================================================

# Required for LM Studio. The base URL for your local LM Studio server.
# Used by the 'lmstudio_router' and 'lmstudio_specialist' providers in user_settings.yaml.
# Download LM Studio: https://lmstudio.ai
LMSTUDIO_BASE_URL="http://localhost:1234/v1"
# LMSTUDIO_TIMEOUT=180

# TIERED CHAT TIP: Use LM Studio for one or both progenitors to:
# - Eliminate API costs (especially during development/testing)
# - Run fully offline/private conversations
# - Mix with cloud models (hybrid strategy: one local, one cloud)
# Recommended local models for progenitors:
# - Llama 3 8B Instruct (good quality, fast)
# - Phi-3 Medium (efficient, good reasoning)
# - Mistral 7B Instruct (versatile, well-rounded)

# OLLAMA SUPPORT - NOT YET IMPLEMENTED
# The Ollama adapter is planned but not currently available.
# Uncomment and configure when Ollama support is added:
# OLLAMA_BASE_URL="http://localhost:11434"

# Enable and set an output path to enable Archiver reports 
# AGENTIC_SCAFFOLD_ARCHIVER_ENABLED="true"
# AGENTIC_SCAFFOLD_ARCHIVE_PATH="/path/to/my/reports"

# Control integration with LangSmith to trace the scaffold's LangGraph process flow
# export LANGSMITH_TRACING="true"
# export LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# export LANGSMITH_API_KEY="<your-api-key>"
# export LANGSMITH_PROJECT="<your-langsmith-project>"

# *Currently only related to your LangSmith configuration*
# export OPENAI_API_KEY=<your-openai-api-key>