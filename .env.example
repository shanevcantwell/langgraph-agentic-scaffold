# .env.example

# ===================================================================
#  LLM Provider Configuration
# ===================================================================
# This file stores secrets and connection details for LLM providers.
# Copy this file to .env and fill in the required values.

# Required for Google Gemini. Your API key for the Google AI platform.
# Used by the 'gemini_pro' and 'gemini_flash' providers in config.yaml.
GOOGLE_API_KEY="your-google-api-key"

# Required for LM Studio. The base URL for your local LM Studio server.
# Used by the 'lmstudio_router' and 'lmstudio_specialist' providers in config.yaml.
LMSTUDIO_BASE_URL="http://localhost:1234/v1"
# LMSTUDIO_TIMEOUT=180

# --- Optional: LM Studio SSH Auto-loading ---
# *In testing*
# If these variables are set, the system will attempt to automatically load a model
# on a remote inference server if it's not already loaded. This requires passwordless
# SSH access (using a private key).
# The host/IP of your Ubuntu inference server
# LMSTUDIO_SSH_HOST="192.168.1.100"
# The user to connect as
# LMSTUDIO_SSH_USER="ubuntu"
# The absolute path to your private SSH key for passwordless login
# LMSTUDIO_SSH_KEY_PATH="/home/user/.ssh/id_rsa"

# Required for Ollama. The base URL for your local Ollama server.
# Used by the 'ollama' provider in config.yaml.
# *Not yet implemented*
# OLLAMA_BASE_URL="http://localhost:11434"

# Enable and set an output path to enable Archiver reports 
# AGENTIC_SCAFFOLD_ARCHIVER_ENABLED=false
# AGENTIC_SCAFFOLD_ARCHIVE_PATH=/path/to/my/reports

# Control integration with LangSmith to trace the scaffold's LangGraph process flow
# export LANGCHAIN_TRACING_V2="true"
# export LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# export LANGSMITH_API_KEY="<your-api-key>"
# export LANGSMITH_PROJECT="<your-langsmith-project>"

# *Currently only related to your LangSmith configuration*
# export OPENAI_API_KEY=<your-openai-api-key>