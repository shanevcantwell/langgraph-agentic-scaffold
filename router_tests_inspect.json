      "input": "What's in this image?",
      "metadata": {
        "category": "image_handling",
        "notes": "Must follow image detection directive",
        "system_prompt": "You are a Router specialist.\n\n**CRITICAL: IMAGE DETECTED**\nThe user has uploaded an image. You cannot see it, but it is available in the artifacts. You MUST route to a specialist capable of vision analysis. Recommended: image_specialist."
      },
      "target": {
        "tool_calls": [{"function": "route", "arguments": {"next_specialist": "image_specialist"}}]
      },
      "tools": [{"type": "function", "function": {"name": "route", "parameters": {"type": "object", "properties": {"next_specialist": {"type": "string", "enum": ["chat_specialist", "text_analysis_specialist", "file_operations_specialist", "image_specialist", "end_specialist"]}}, "required": ["next_specialist"]}}}],
      "tool_choice": "required"
    },
    {
      "id": "router_blocked_specialist",
      "input": "Create a simple webpage for my portfolio",
      "metadata": {
        "category": "loop_recovery",
        "notes": "Must NOT choose web_builder despite being relevant",
        "system_prompt": "You are a Router specialist.\n\n**LOOP RECOVERY ACTIVE**\nThe following specialists are temporarily BLOCKED due to repeated failures: web_builder\nDo NOT route to blocked specialists. Choose an alternative approach."
      },
      "target": {
        "tool_calls_exclude": ["web_builder"],
        "tool_calls_any": [{"function": "route", "arguments": {"next_specialist": "systems_architect"}}, {"function": "route", "arguments": {"next_specialist": "chat_specialist"}}]
      },
      "tools": [{"type": "function", "function": {"name": "route", "parameters": {"type": "object", "properties": {"next_specialist": {"type": "string", "enum": ["chat_specialist", "text_analysis_specialist", "file_operations_specialist", "web_builder", "systems_architect", "end_specialist"]}}, "required": ["next_specialist"]}}}],
      "tool_choice": "required"
    },
