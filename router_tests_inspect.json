      "target": {
        "tool_calls": [{"function": "route", "arguments": {"next_specialist": "systems_architect"}}]
      },
      "tools": [{"type": "function", "function": {"name": "route", "parameters": {"type": "object", "properties": {"next_specialist": {"type": "string", "enum": ["chat_specialist", "web_builder", "systems_architect", "file_operations_specialist", "end_specialist"]}}, "required": ["next_specialist"]}}}],
      "tool_choice": "required"
    },
