{
  "name": "las_router_tests",
  "description": "Realistic LAS Router routing tests with full specialist menus and contextual prompts",
  "samples": [
    {
      "id": "router_simple_chat",
      "input": "What is the capital of France?",
      "metadata": {
        "category": "simple_routing",
        "expected": "chat_specialist",
        "system_prompt": "You are a Router specialist in an agentic system. Your job is to analyze the user's request and route it to the most appropriate specialist.\n\nBased on the current context, you MUST choose a specialist from the following list:\n\n- chat_specialist: Handles general conversational queries, questions, and casual interactions.\n- text_analysis_specialist: Analyzes, summarizes, or extracts specific information from documents.\n- file_operations_specialist: User interface for file system operations.\n- batch_processor_specialist: Handles batch file operations.\n- web_builder: Builds or modifies web UIs.\n- systems_architect: Creates high-level technical plans.\n- data_extractor_specialist: Extracts structured data from unstructured text.\n- sentiment_classifier_specialist: Classifies sentiment.\n- researcher_specialist: Performs web searches and research.\n- image_specialist: Analyzes images.\n- end_specialist: Completes workflow."
      },
      "target": {
        "tool_calls": [{"function": "route", "arguments": {"next_specialist": "chat_specialist"}}]
      },
      "tools": [{"type": "function", "function": {"name": "route", "description": "Route to specialist", "parameters": {"type": "object", "properties": {"next_specialist": {"type": "string", "enum": ["chat_specialist", "text_analysis_specialist", "file_operations_specialist", "batch_processor_specialist", "web_builder", "systems_architect", "data_extractor_specialist", "sentiment_classifier_specialist", "researcher_specialist", "image_specialist", "end_specialist"]}}, "required": ["next_specialist"]}}}],
      "tool_choice": "required"
    },
    {
      "id": "router_file_list",
      "input": "List all the files in the workspace directory",
      "metadata": {
        "category": "simple_routing",
        "expected": "file_operations_specialist"
