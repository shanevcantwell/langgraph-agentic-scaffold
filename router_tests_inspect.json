      "tools": [{"type": "function", "function": {"name": "route", "parameters": {"type": "object", "properties": {"next_specialist": {"type": "string", "enum": ["chat_specialist", "text_analysis_specialist", "file_operations_specialist", "batch_processor_specialist", "web_builder", "systems_architect", "researcher_specialist", "image_specialist", "end_specialist"]}}, "required": ["next_specialist"]}}}],
