# .gitignore

# --- Environment ---
# Ignore local environment variables. Never commit secrets.
.env
.run
user_settings.yaml

# --- Python ---
# Ignore cache files, compiled files, and virtual environments.
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# --- IDE / Editor ---
# Ignore editor-specific configuration files.
.vscode/
*.code-workspace

__pycache__/*
src/__pycache__/*
*/.pytest_cache/*
.venv*/
logs/
*.bak
docs/adr/private/*
app/src/ui/*.html

# --- External Code ---
# Ignore contents of the external directory, but keep the directory itself.
# We make an exception for our own Python wrapper files.
external_agents/*
!external_agents/.gitkeep
!external_agents/**/*.py

# --- Lock file for unsupervised code execution ---
.unsupervised_execution.lock

# agent safe file workspace
workspace/*

# proxy config
proxy/*
!proxy/squid.conf.example
!proxy/Dockerfile

# symlink
docs/ADRs
.docker-images

# generated
requirements*.txt
build/

# backups
*.bak

# local config
langgraph-agentic-scaffold.code-workspace
config.yaml
.continue/*
.docker_tmp/

# output
data/*
logs/*

# docker workspace
workspace/
tests/
