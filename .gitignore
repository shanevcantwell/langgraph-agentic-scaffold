# .gitignore

# --- Environment ---
# Ignore local environment variables. Never commit secrets.
.env
.run
user_settings.yaml

# --- Python ---
# Ignore cache files, compiled files, and virtual environments.
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# --- IDE / Editor ---
# Ignore editor-specific configuration files.
.vscode/
*.code-workspace

__pycache__/*
src/__pycache__/*
src/agents/__pycache__/*
src/graph/__pycache__/*
*/.pytest_cache/*
.venv*/
app/windows_run.bat
output.html
app/output.html
backups/
build/
logs/
*.bak
docs/adr/private/*
app/src/ui/*.html

# --- External Code ---
# Ignore contents of the external directory, but keep the directory itself.
# We make an exception for our own Python wrapper files.
external_agents/*
!external_agents/.gitkeep
!external_agents/**/*.py

runverify.sh

# --- Lock file for unsupervised code execution ---
.unsupervised_execution.lock
workspace/*


ui.sh
runverify.sh
archives/*
docs/ADR/*
proxy/*
!proxy/squid.conf.example
.continue/*
audit_manifest.md
.gitignore
audit_manifest.md
.continue/*
