# /proxy/squid.conf - Whitelist configuration for Squid Proxy

# Define standard ports
acl SSL_ports port 443
acl Safe_ports port 80       # http
acl Safe_ports port 443      # https
# acl Safe_ports port 1234     # LM Studio

# --- Define Whitelisted Domains ---
# Create an ACL for the domains your agent is allowed to contact.
# Add or remove domains as needed.
acl allowed_domains dstdomain .pypi.org          # For Python package installation
acl allowed_domains dstdomain .github.com        # For source code and assets
acl allowed_domains dstdomain .huggingface.co    # For models and datasets
acl allowed_domains dstdomain .googleapis.com    # For Google Gemini API
acl allowed_domains dstdomain api.smith.langchain.com # For LangSmith

# acl allowed_domains dstdomain <your-LMStudio-server>  # For LM Studio

# --- Access Rules ---
# Deny requests to non-standard ports
http_access deny !Safe_ports
# Deny requests for insecure SSL connections
http_access deny CONNECT !SSL_ports

# Allow access ONLY to the whitelisted domains
http_access allow allowed_domains

# To enforce the whitelist strictly, uncomment the line below.
# This will block any request to a domain not listed above.
# http_access deny all

# Set the port Squid will listen on
http_port 3128