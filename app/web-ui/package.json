{
  "name": "vegas-terminal-ui",
  "version": "1.0.0",
  "description": "Visual Agentic-Scaffold Terminal UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/public/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "public/app.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/public/marked.min.js"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0"
  }
}
