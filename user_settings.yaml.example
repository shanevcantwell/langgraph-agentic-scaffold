# ==============================================================================
# USER-LEVEL SETTINGS
# This file is for your local environment. It defines WHICH concrete models to
# use and HOW to assign them to the specialists from `config.yaml`.
#
# It is safe to edit and is not tracked by Git.
# ==============================================================================

# --- 1. Define Your Concrete Models ---
# This section defines your named LLM provider configurations. Each configuration
# must have a `type` (which maps to an adapter) and an `api_identifier` (the model name).
llm_providers:
  # For cloud providers, this is the API model name.
  gemini_flash:
    type: "gemini"
    api_identifier: "gemini-2.5-flash"
  gemini_pro:
    type: "gemini"
    api_identifier: "gemini-2.5-pro"

  # For local providers (like LM Studio), this is typically the model file path/name
  # that the server is loading.
  lmstudio_router:
    type: "lmstudio"
    api_identifier: "gpt-oss-20b"   # Tested to be excellent router when prompted well
  lmstudio_specialist:
    type: "lmstudio"
    api_identifier: "QuantFactory/Meta-Llama-3-8B-Instruct-GGUF/meta-llama-3-8b-instruct.Q8_0.gguf"

  # OLLAMA SUPPORT - Use https://github.com/shanevcantwell/ollama-shim  # The Ollama adapter is planned but not currently available.
  # See app/src/llm/factory.py line 17 for implementation status.
  # Uncomment the section below once Ollama support is added:
  # ollama_local:
  #   type: "ollama"
  #   api_identifier: "llama3:8b"


# --- 2. Assign Models to Specialists ---
# This section binds the abstract specialists (from config.yaml) to one of the
# fully-defined provider configurations from above.
specialist_model_bindings:
  systems_architect: "gemini_flash"
  prompt_specialist: "gemini_flash"
  chat_specialist: "gemini_flash"

  # --- Orchestration Bindings ---
  # It's critical to bind the core orchestrators explicitly.
  router_specialist: "lmstudio_router"
  prompt_triage_specialist: "gemini_flash"

  # --- Hybrid Specialist Bindings ---
  # The Open Interpreter specialist is hybrid, requiring an LLM for planning.
  # The End Specialist is hybrid, using an LLM for response synthesis.
  # You MUST bind them to an LLM provider here for them to work.
  open_interpreter_specialist: "gemini_flash"
  end_specialist: "gemini_flash"

  # --- Tiered Chat Subgraph Bindings (CORE-CHAT-002) ---
  # ===========================================================================
  # PROGENITOR MODEL ASSIGNMENT STRATEGIES
  # ===========================================================================
  # The tiered chat subgraph executes both progenitors IN PARALLEL for every
  # user question. Choose your model assignment based on your priorities:
  #
  # STRATEGY 1: COST OPTIMIZATION (Recommended for Development/Testing)
  # - Use local models (LM Studio) for one or both progenitors
  # - Zero API costs, but requires local GPU/CPU resources
  # - Example: Both progenitors use lmstudio_specialist (FREE)
  # - Note: Ollama is not yet implemented (see llm_providers section above)
  #
  # STRATEGY 2: QUALITY OPTIMIZATION (Recommended for Production)
  # - Use premium cloud models (Gemini Pro, GPT-5) for both progenitors
  # - Best response quality, but 2x API cost per turn
  # - Example: Both progenitors use gemini_pro (PREMIUM)
  #
  # STRATEGY 3: HYBRID OPTIMIZATION (Recommended for Most Use Cases)
  # - Mix cloud and local: quality where it matters, cost savings elsewhere
  # - One progenitor uses cloud (Gemini Flash, GPT-4), one uses local (LM Studio)
  # - Good balance of quality and cost
  # - Example below: Alpha=cloud (fast), Bravo=local (free)
  #
  # STRATEGY 4: DIFFERENTIATED MODELS (Advanced)
  # - Assign different cloud models to each progenitor for diverse perspectives
  # - Example: Alpha=gemini_pro (depth), Bravo=gemini_flash (speed)
  #
  # CONFIGURATION TIPS:
  # - Alpha is typically analytical/structured - consider faster/cheaper models
  # - Bravo is typically intuitive/contextual - consider higher quality models
  # - For multi-turn conversations, both progenitors see full history
  # - Test with local models first, upgrade to cloud for production
  # ===========================================================================

  progenitor_alpha_specialist: "gemini_flash"  # Analytical perspective (cloud, fast)
  progenitor_bravo_specialist: "lmstudio_specialist"  # Contextual perspective (local, free)

  # ALTERNATIVE CONFIGURATIONS (uncomment to try):
  # Both Cloud (Premium Quality):
  # progenitor_alpha_specialist: "gemini_pro"
  # progenitor_bravo_specialist: "gemini_pro"
  #
  # Both Local (Zero Cost):
  # progenitor_alpha_specialist: "lmstudio_specialist"
  # progenitor_bravo_specialist: "lmstudio_specialist"
  #
  # Differentiated Cloud (Diverse Perspectives):
  # progenitor_alpha_specialist: "gemini_flash"  # Speed-optimized
  # progenitor_bravo_specialist: "gemini_pro"    # Quality-optimized

  # Note: tiered_synthesizer_specialist is procedural and doesn't need a model binding
  # It simply formats the progenitor responses into tiered markdown output.

# --- 3. Set the Default ---
# The default LLM configuration to use for any specialist that is not
# explicitly bound above. This must match a key from the providers defined above.
default_llm_config: "gemini_flash"

# Standard clean UI (default)
ui_module: "gradio_app"     # most basic sample UI
# ui_module: "gradio_vegas"   # retro scifi terminal UI
# ui_module: "gradio_lassi"   # mango yogurt drink UI
